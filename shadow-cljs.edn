{:source-paths ["src/main" "src/test"]
 :dev-http {9500 "public"}
 :dependencies [[reagent "1.2.0"]]

 :builds
 {:app {:target     :browser
        :output-dir "public/js"
        :asset-path "/js"
        :modules    {:main {:init-fn goeburst.app/init}}}

  :test {:target    :node-test
         :output-to "target/test/test.js"
         :ns-regexp "-test$"}}}
