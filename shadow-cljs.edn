{:source-paths
 ["src/dev" 
  "src/main" 
  "src/test"]
 :dev-http {8080 "resources/public"}
 :builds
 {:app {:deps true
        :target :browser
        :devtools {:preloads [uix.preload]}
        :output-dir "resources/public/js"
        :asset-path "/js"
        :modules    {:main {:init-fn span.app/init}}}

  :test {:deps true
         :target    :node-test
         :output-to "target/test/test.js"
         :ns-regexp "-test$"}}}
